<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#101218">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🔴 Live Mode Consent"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textSize="22sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="ARIA will listen in foreground with visible notification. You can stop anytime from notification or Safety Center."
        android:textColor="#B6C0D1"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/liveConsentStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:textColor="#FFFFFF"
        android:text="No active session"
        android:textSize="13sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/startLive15mButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:text="Start Live for 15 Minutes"
        app:cornerRadius="12dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/startLive60mButton"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Start Live for 60 Minutes"
        app:cornerRadius="12dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/cancelLiveButton"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Cancel" />

</LinearLayout>
