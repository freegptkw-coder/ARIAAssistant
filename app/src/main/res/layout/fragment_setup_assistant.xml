<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#101218">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Default Assistant"
        android:textStyle="bold"
        android:textSize="18sp"
        android:textColor="#FFFFFF" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Set ARIA as your default digital assistant for voice invocation."
        android:textColor="#AAB2C0"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/assistantStatusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="❌ ARIA not default assistant"
        android:textColor="#FFFFFF"
        android:textSize="14sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/setAssistantButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Set ARIA as Default Assistant"
        app:cornerRadius="12dp" />

</LinearLayout>
